	<div id="shortcuts-modal" class="modal" hidden role="dialog" aria-labelledby="shortcuts-title" aria-modal="true">
		<div class="modal-backdrop" data-close-modal tabindex="-1"></div>
		<div class="modal-panel" role="document">
			<h2 id="shortcuts-title" class="modal-title">Atajos de teclado</h2>
			<dl class="shortcut-list">
				<dt><kbd>/</kbd></dt><dd>Enfocar búsqueda</dd>
				<dt><kbd>?</kbd></dt><dd>Mostrar esta ayuda</dd>
				<dt><kbd>j</kbd> / <kbd>k</kbd></dt><dd>Sección siguiente / anterior</dd>
				<dt><kbd>Esc</kbd></dt><dd>Cerrar ayuda / limpiar búsqueda</dd>
				<dt>URL <code>?q=</code></dt><dd>Compartir el filtro de búsqueda</dd>
				<dt><kbd>g</kbd></dt><dd>Ir a repositorios GitHub</dd>
				<dt><kbd>1</kbd>–<kbd>9</kbd></dt><dd>Ir a sección por orden (nav)</dd>
				<dt><kbd>`</kbd> (backtick)</dt><dd>Abrir/cerrar terminal ficticia</dd>
			</dl>
			<button type="button" class="btn-modal-close" data-close-modal>Cerrar</button>
		</div>
	</div>

