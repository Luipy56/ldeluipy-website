	<div id="boot-overlay" class="boot-overlay" hidden>
		<div class="boot-overlay-inner">
			<p class="boot-line">ldeluipy.es // arranque del hub</p>
			<p class="boot-line" id="boot-msg">Inicializando interfaz…</p>
			<div class="boot-bar-wrap" aria-hidden="true"><div class="boot-bar" id="boot-bar"></div></div>
			<div class="boot-actions">
				<button type="button" class="boot-skip" id="boot-skip">Saltar</button>
				<button type="button" class="boot-go" id="boot-go" hidden>Entrar</button>
			</div>
		</div>
