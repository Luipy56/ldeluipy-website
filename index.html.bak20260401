		<defs>
			<pattern id="hubGridPat" width="8" height="8" patternUnits="userSpaceOnUse">
				<path d="M 8 0 L 0 0 0 8" fill="none" stroke="currentColor" stroke-width="0.15" opacity="0.4"/>
			</pattern>
		</defs>
		<rect width="100" height="100" fill="url(#hubGridPat)"/>
	</svg>
